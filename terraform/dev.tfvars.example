# 복사해서 dev.tfvars로 저장 후 실제 값 입력
# dev.tfvars는 .gitignore 처리되어 있음 — 절대 커밋 금지

# OCI 계정 정보 (OCI Console → Identity → Tenancy/Compartment에서 확인)
tenancy_ocid     = "ocid1.tenancy.oc1..aaaaaaaa..."
compartment_ocid = "ocid1.compartment.oc1..aaaaaaaa..."
region           = "ap-chuncheon-1"  # 한국(춘천) region

# SSH 공개키 (인스턴스 접속용)
# 로컬에서: cat ~/.ssh/id_ed25519.pub
ssh_public_key = "ssh-ed25519 AAAA... user@host"

# K3s 노드 간 인증 토큰 (server <-> agent join 시 사용)
# 생성: openssl rand -hex 32
k3s_token = "REPLACE_WITH_RANDOM_HEX"

# OCI Object Storage (etcd 스냅샷 백업용)
# Console → Object Storage → Bucket → Customer Secret Keys에서 발급
oci_s3_endpoint   = "https://<namespace>.compat.objectstorage.ap-chuncheon-1.oraclecloud.com"
oci_s3_bucket     = "infra-backup-dev"
oci_s3_access_key = "REPLACE"
oci_s3_secret_key = "REPLACE"

# GitOps 소스 — ArgoCD가 sync할 INFRA 레포
github_infra_repo = "https://github.com/<user>/INFRA.git"
github_infra_path = "argocd/apps"
github_infra_branch = "dev"

# 환경 이름 (cluster name, tag 등에 사용)
env_name = "dev"
